/* pages/calendar/calendar.wxss - 卦历页面 */

.page {
  min-height: 100vh;
  background-color: #F7F4EE;
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
  padding-top: env(safe-area-inset-top);
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

.year-header {
  padding: 64rpx 0 32rpx 0;
  text-align: center;
}

.year-title {
  font-size: 32rpx;
  color: #8B8B8B;
  letter-spacing: 4rpx;
}

.year-grid {
  flex: 1;
  overflow-y: auto;
}

.months-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding-bottom: 120rpx;
}

.month-block {
  width: 48%;
  margin-bottom: 32rpx;
  background-color: rgba(255, 255, 255, 0.5);
  border-radius: 16rpx;
  padding: 24rpx;
}

.month-title {
  font-size: 24rpx;
  color: #8B8B8B;
  margin-bottom: 16rpx;
  text-align: center;
}

.month-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4rpx;
}

.day-cell {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.day-cell.empty {
  visibility: hidden;
}

.day-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.day-num {
  font-size: 22rpx;
  color: #1C1C1C;
}

.day-cell.today .day-num {
  color: #9F2D20;
  font-weight: 600;
}

.entry-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background-color: #1C1C1C;
  margin-top: 4rpx;
}

.day-cell.has-entry .entry-dot {
  background-color: #9F2D20;
}

.lunar-day {
  font-size: 16rpx;
  color: #BDBDBD;
  margin-top: 2rpx;
  position: absolute;
  bottom: 2rpx;
}

.day-cell.today {
  background-color: rgba(159, 45, 32, 0.05);
  border-radius: 8rpx;
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  padding: 24rpx 64rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #F7F4EE;
}

.nav-item {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.5;
}

.nav-item.active {
  opacity: 1;
}

.calendar-icon {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #1C1C1C;
  border-radius: 8rpx;
  position: relative;
}

.calendar-icon::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 8rpx;
  border: 2rpx solid #1C1C1C;
  border-bottom: none;
  border-radius: 4rpx 4rpx 0 0;
}

.settings-icon {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #1C1C1C;
  border-radius: 50%;
  position: relative;
}

.settings-icon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 12rpx;
  height: 12rpx;
  background-color: #1C1C1C;
  border-radius: 50%;
}

.settings-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 4rpx;
  height: 16rpx;
  background-color: #1C1C1C;
  border-radius: 2rpx;
}

/* 详情弹窗 */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease-out;
}

.detail-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.detail-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(247, 244, 238, 0.95);
}

.detail-card {
  position: relative;
  z-index: 1;
  width: 600rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.detail-date {
  text-align: center;
  font-size: 24rpx;
  color: #8B8B8B;
  margin-bottom: 32rpx;
}

.detail-chars {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.char-left, .char-right {
  font-size: 36rpx;
  color: #E0DDD5;
}

.detail-char {
  font-size: 72rpx;
  color: #1C1C1C;
  font-weight: 600;
  letter-spacing: 16rpx;
}

.detail-hexagram {
  text-align: center;
  padding: 32rpx 0;
  border-top: 1rpx solid #F0EFED;
  border-bottom: 1rpx solid #F0EFED;
  margin-bottom: 32rpx;
}

.detail-hexagram .hexagram-symbol {
  font-size: 100rpx;
  display: block;
  margin-bottom: 16rpx;
}

.detail-hexagram .hexagram-name {
  font-size: 48rpx;
  color: #1C1C1C;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.detail-hexagram .hexagram-title {
  font-size: 24rpx;
  color: #8B8B8B;
  display: block;
  margin-bottom: 24rpx;
}

.detail-hexagram .hexagram-text {
  font-size: 22rpx;
  color: #8B8B8B;
  line-height: 1.8;
  display: block;
}

.detail-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  background-color: #1C1C1C;
  color: #F7F4EE;
  font-size: 28rpx;
  border-radius: 12rpx;
}

.action-btn.close {
  background-color: transparent;
  color: #8B8B8B;
}