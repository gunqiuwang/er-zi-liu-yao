/* pages/calendar/calendar.wxss - 卦历页面 v3 */

.page {
  min-height: 100vh;
  background-color: #F7F4EE;
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
  padding-top: env(safe-area-inset-top);
  padding-bottom: 160rpx;
  box-sizing: border-box;
  font-family: 'LXGW WenKai', 'Songti SC', serif;
}

.year-header {
  padding: 72rpx 0 28rpx 0;
  text-align: center;
}

.year-title {
  font-size: 30rpx;
  color: #8B8B8B;
  letter-spacing: 6rpx;
  font-weight: 300;
}

.year-grid {
  flex: 1;
  overflow-y: auto;
}

.months-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding-bottom: 40rpx;
}

.month-block {
  width: 48%;
  margin-bottom: 28rpx;
  background-color: rgba(255, 255, 255, 0.4);
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
}

.month-title {
  font-size: 22rpx;
  color: #9B9688;
  margin-bottom: 12rpx;
  text-align: center;
  font-weight: 300;
}

.month-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 2rpx;
}

.day-cell {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.day-cell.empty {
  visibility: hidden;
}

.day-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.day-num {
  font-size: 20rpx;
  color: #3A3A3A;
  font-weight: 400;
}

.day-cell.today .day-num {
  color: #9F2D20;
  font-weight: 500;
}

.entry-dot {
  width: 5rpx;
  height: 5rpx;
  border-radius: 50%;
  background-color: #1C1C1C;
  margin-top: 3rpx;
}

.day-cell.has-entry .entry-dot {
  background-color: #9F2D20;
}

.lunar-day {
  font-size: 14rpx;
  color: #BDBDBD;
  margin-top: 1rpx;
  position: absolute;
  bottom: 1rpx;
}

.day-cell.today {
  background-color: rgba(159, 45, 32, 0.04);
  border-radius: 6rpx;
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 0 72rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  background: transparent;
  z-index: 50;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  opacity: 0.4;
  transition: opacity 0.3s ease;
}

.nav-item.active {
  opacity: 1;
}

.nav-item:active {
  opacity: 0.75;
}

.nav-icon {
  width: 48rpx;
  height: 48rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-label {
  font-size: 16rpx;
  color: #6A6A6A;
  letter-spacing: 2rpx;
}

/* 日历 icon */
.calendar-icon {
  width: 40rpx;
  height: 40rpx;
  border: 1.5px solid #4A4A4A;
  border-radius: 8rpx;
  position: absolute;
  opacity: 0.7;
}

.calendar-icon::before {
  content: '';
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  border: 1.5px solid #4A4A4A;
  border-bottom: none;
  border-radius: 3rpx 3rpx 0 0;
  top: -5rpx;
  left: 50%;
  transform: translateX(-50%);
  opacity: 0.7;
}

/* 设置 icon */
.settings-icon {
  width: 40rpx;
  height: 40rpx;
  border: 1.5px solid #4A4A4A;
  border-radius: 50%;
  position: absolute;
  opacity: 0.7;
}

.settings-icon::before {
  content: '';
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background-color: #4A4A4A;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  opacity: 0.7;
}

/* 详情弹窗 */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease-out;
}

.detail-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.detail-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(247, 244, 238, 0.95);
  backdrop-filter: blur(8px);
}

.detail-card {
  position: relative;
  z-index: 1;
  width: 540rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 44rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.detail-date {
  text-align: center;
  font-size: 22rpx;
  color: #8B8B8B;
  margin-bottom: 28rpx;
  letter-spacing: 2rpx;
}

.detail-chars {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.char-left, .char-right {
  font-size: 32rpx;
  color: #E0DCD4;
}

.detail-char {
  font-size: 64rpx;
  color: #1C1C1C;
  font-weight: 600;
  letter-spacing: 12rpx;
  font-family: 'LXGW WenKai', serif;
}

.detail-hexagram {
  text-align: center;
  padding: 28rpx 0;
  border-top: 1rpx solid #F0EFED;
  border-bottom: 1rpx solid #F0EFED;
  margin-bottom: 28rpx;
}

.detail-hexagram .hexagram-symbol {
  font-size: 88rpx;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1;
}

.detail-hexagram .hexagram-name {
  font-size: 44rpx;
  color: #1C1C1C;
  font-weight: 600;
  display: block;
  margin-bottom: 6rpx;
}

.detail-hexagram .hexagram-title {
  font-size: 22rpx;
  color: #8B8B8B;
  display: block;
  margin-bottom: 20rpx;
}

.detail-hexagram .hexagram-text {
  font-size: 20rpx;
  color: #8B8B8B;
  line-height: 1.8;
  display: block;
}

.detail-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background-color: #1C1C1C;
  color: #F7F4EE;
  font-size: 26rpx;
  border-radius: 8rpx;
}

.action-btn.close {
  background-color: transparent;
  color: #8B8B8B;
}