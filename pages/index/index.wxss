/* pages/index/index.wxss - 东方极简风格 v3 */

/* === 字体引入 === */
@font-face {
  font-family: 'LXGW WenKai';
  src: url('https://cdn.jsdelivr.net/npm/lxgw-wenkai-webfont@1.1.0/LXGW wenkai-Regular.woff2') format('woff2');
  font-weight: normal;
  font-style: normal;
}

@font-face {
  font-family: 'LXGW WenKai';
  src: url('https://cdn.jsdelivr.net/npm/lxgw-wenkai-webfont@1.1.0/LXGW wenkai-Bold.woff2') format('woff2');
  font-weight: bold;
  font-style: normal;
}

/* === 基础页面 === */
.page {
  min-height: 100vh;
  background-color: #F7F4EE;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
  padding-top: env(safe-area-inset-top);
  padding-bottom: 160rpx;
  box-sizing: border-box;
  position: relative;
  font-family: 'LXGW WenKai', 'Songti SC', 'STSong', serif;
}

/* === 顶部日期区 === */
.date-header {
  display: flex;
  align-items: center;
  margin-top: 80rpx;
  gap: 20rpx;
}

.lunar-date {
  font-size: 24rpx;
  color: #8B8B8B;
  letter-spacing: 6rpx;
  font-weight: 300;
}

.today-mark {
  font-size: 18rpx;
  color: #FFFFFF;
  background-color: #9F2D20;
  padding: 4rpx 14rpx;
  border-radius: 3rpx;
  letter-spacing: 2rpx;
  opacity: 0.9;
}

/* === 二字展示区 === */
.chars-section {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  min-height: 360rpx;
}

.char-left, .char-right {
  font-size: 44rpx;
  color: #E8E4DC;
  font-weight: 200;
}

.chars {
  font-size: 144rpx;
  color: #1C1C1C;
  font-weight: 600;
  letter-spacing: 20rpx;
  transition: all 0.5s ease-out;
  font-family: 'LXGW WenKai', 'Songti SC', serif;
}

.chars.empty {
  color: #E0DCD4;
}

/* === 功能按钮组（统一风格）=== */
.action-group {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 64rpx;
  padding: 48rpx 0 32rpx;
}

/* 单个按钮基础样式 */
.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  opacity: 0.5;
  transition: opacity 0.3s ease;
}

.action-btn:active {
  opacity: 0.8;
}

/* === 铜钱按钮 === */
.coin-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.coin {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: radial-gradient(
    circle at 35% 35%,
    #A08560 0%,
    #7A6040 50%,
    #5A4530 100%
  );
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: transform 0.5s ease-out, opacity 0.3s ease;
}

.coin::before {
  content: '';
  position: absolute;
  width: 152rpx;
  height: 152rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.coin.touched {
  animation: coinTouch 0.6s ease-out;
}

@keyframes coinTouch {
  0% { transform: rotate(0deg); }
  25% { transform: rotate(6deg); opacity: 0.85; }
  50% { transform: rotate(-4deg); opacity: 0.9; }
  75% { transform: rotate(2deg); }
  100% { transform: rotate(0deg); opacity: 1; }
}

.coin-hole {
  width: 22rpx;
  height: 22rpx;
  background-color: #F7F4EE;
  border-radius: 4rpx;
}

.coin-label {
  font-size: 18rpx;
  color: #A0A0A0;
  letter-spacing: 2rpx;
}

/* === 分享按钮 === */
.share-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.share-icon {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.share-icon::before {
  content: '';
  position: absolute;
  width: 48rpx;
  height: 48rpx;
  border: 1.5px solid #6B6B6B;
  border-radius: 50%;
  opacity: 0.6;
}

.share-icon::after {
  content: '';
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  border-top: 1.5px solid #6B6B6B;
  border-right: 1.5px solid #6B6B6B;
  transform: rotate(-45deg);
  top: 22rpx;
  left: 36rpx;
  opacity: 0.6;
}

.share-label {
  font-size: 18rpx;
  color: #A0A0A0;
  letter-spacing: 2rpx;
}

/* === 底部导航 === */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 0 72rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  background: transparent;
  z-index: 50;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  opacity: 0.4;
  transition: opacity 0.3s ease;
}

.nav-item:active {
  opacity: 0.75;
}

/* 日历 icon */
.nav-icon {
  width: 48rpx;
  height: 48rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.calendar-icon {
  width: 40rpx;
  height: 40rpx;
  border: 1.5px solid #4A4A4A;
  border-radius: 8rpx;
  position: absolute;
  opacity: 0.7;
}

.calendar-icon::before {
  content: '';
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  border: 1.5px solid #4A4A4A;
  border-bottom: none;
  border-radius: 3rpx 3rpx 0 0;
  top: -5rpx;
  left: 50%;
  transform: translateX(-50%);
  opacity: 0.7;
}

.nav-label {
  font-size: 16rpx;
  color: #6A6A6A;
  letter-spacing: 2rpx;
}

/* 设置 icon */
.settings-icon {
  width: 40rpx;
  height: 40rpx;
  border: 1.5px solid #4A4A4A;
  border-radius: 50%;
  position: absolute;
  opacity: 0.7;
}

.settings-icon::before {
  content: '';
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background-color: #4A4A4A;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  opacity: 0.7;
}

/* === 输入弹窗 === */
.input-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.35s ease-out;
}

.input-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.input-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.45);
  backdrop-filter: blur(4px);
}

.input-card {
  position: relative;
  z-index: 1;
  width: 560rpx;
  background-color: #F7F4EE;
  border-radius: 20rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.08);
}

.input-header {
  text-align: center;
  margin-bottom: 36rpx;
}

.input-title {
  font-size: 28rpx;
  color: #1C1C1C;
  font-weight: 500;
  letter-spacing: 4rpx;
  font-family: 'LXGW WenKai', serif;
}

.input-field {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.input-bracket {
  font-size: 44rpx;
  color: #D8D4CC;
  font-weight: 200;
}

.input-box {
  width: 240rpx;
  height: 100rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  font-size: 56rpx;
  text-align: center;
  letter-spacing: 12rpx;
  border: none;
  outline: none;
  font-family: 'LXGW WenKai', serif;
}

.input-box::placeholder {
  color: #D8D4CC;
}

.input-hint {
  text-align: center;
  font-size: 20rpx;
  color: #BDBDBD;
  margin-bottom: 32rpx;
  font-family: 'LXGW WenKai', serif;
}

.input-actions {
  display: flex;
  gap: 12rpx;
}

.input-btn {
  flex: 1;
  text-align: center;
  padding: 22rpx;
  font-size: 26rpx;
  border-radius: 10rpx;
  border: none;
  cursor: pointer;
  font-family: 'LXGW WenKai', serif;
}

.input-btn.cancel {
  background-color: transparent;
  color: #8B8B8B;
}

.input-btn.confirm {
  background-color: #1C1C1C;
  color: #F7F4EE;
}

.input-btn::after {
  border: none;
}

/* === 卦象展开面板 === */
.hexagram-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.5s ease-out;
}

.hexagram-panel.show {
  opacity: 1;
  pointer-events: auto;
}

.hexagram-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(247, 244, 238, 0.96);
  backdrop-filter: blur(8px);
}

.hexagram-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 64rpx;
}

.hexagram-symbol {
  font-size: 180rpx;
  color: #1C1C1C;
  margin-bottom: 24rpx;
  opacity: 0;
  transform: scale(0.85);
  transition: all 0.6s ease-out;
  line-height: 1;
  font-family: 'LXGW WenKai', serif;
}

.hexagram-panel.show .hexagram-symbol {
  opacity: 1;
  transform: scale(1);
  transition-delay: 0.2s;
}

.hexagram-name {
  font-size: 56rpx;
  color: #1C1C1C;
  font-weight: 600;
  margin-bottom: 6rpx;
  opacity: 0;
  transition: opacity 0.5s ease-out;
  font-family: 'LXGW WenKai', serif;
}

.hexagram-panel.show .hexagram-name {
  opacity: 1;
  transition-delay: 0.4s;
}

.hexagram-title {
  font-size: 26rpx;
  color: #8B8B8B;
  margin-bottom: 48rpx;
  opacity: 0;
  transition: opacity 0.5s ease-out;
  font-family: 'LXGW WenKai', serif;
}

.hexagram-panel.show .hexagram-title {
  opacity: 1;
  transition-delay: 0.5s;
}

.hexagram-lines {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 48rpx;
  align-items: center;
}

.line-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  opacity: 0;
  transform: translateY(16rpx);
  transition: all 0.4s ease-out;
}

.line-item.show {
  opacity: 1;
  transform: translateY(0);
}

.line-yao {
  font-size: 20rpx;
  color: #9B9688;
  width: 36rpx;
  text-align: right;
  font-weight: 300;
}

.line-shape {
  width: 100rpx;
  height: 12rpx;
  display: flex;
  align-items: center;
}

.yang-line {
  width: 100rpx;
  height: 6rpx;
  background-color: #1C1C1C;
  border-radius: 3rpx;
}

.yin-line {
  width: 100rpx;
  height: 6rpx;
  background: linear-gradient(
    to right,
    #1C1C1C 0%,
    #1C1C1C 42%,
    transparent 42%,
    transparent 58%,
    #1C1C1C 58%,
    #1C1C1C 100%
  );
  border-radius: 3rpx;
}

.line-changing .yang-line,
.line-changing .yin-line {
  background-color: #9F2D20;
  opacity: 0.7;
}

.hexagram-text {
  font-size: 24rpx;
  color: #8B8B8B;
  line-height: 1.9;
  text-align: center;
  max-width: 480rpx;
  opacity: 0;
  transition: opacity 0.5s ease-out;
  font-family: 'LXGW WenKai', serif;
}

.hexagram-panel.show .hexagram-text {
  opacity: 1;
  transition-delay: 0.7s;
}

.close-hint {
  margin-top: 80rpx;
  font-size: 20rpx;
  color: #C0BCB4;
  letter-spacing: 3rpx;
  opacity: 0;
  transition: opacity 0.5s ease-out;
  font-family: 'LXGW WenKai', serif;
}

.hexagram-panel.show .close-hint {
  opacity: 1;
  transition-delay: 1s;
}

/* === 分享弹窗 === */
.share-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease-out;
}

.share-modal.show {
  opacity: 1;
  pointer-events: auto;
}

.share-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(4px);
}

.share-card {
  width: 540rpx;
  background-color: #F7F4EE;
  padding: 56rpx 48rpx;
  position: relative;
  z-index: 1;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.1);
}

.share-card-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.share-date {
  font-size: 22rpx;
  color: #8B8B8B;
  letter-spacing: 6rpx;
  font-weight: 300;
  font-family: 'LXGW WenKai', serif;
}

.share-chars {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 36rpx;
}

.share-char-left, .share-char-right {
  font-size: 32rpx;
  color: #E0DCD4;
}

.share-char {
  font-size: 72rpx;
  color: #1C1C1C;
  font-weight: 600;
  letter-spacing: 12rpx;
  font-family: 'LXGW WenKai', serif;
}

.share-hexagram-symbol {
  display: block;
  text-align: center;
  font-size: 100rpx;
  color: #1C1C1C;
  margin-bottom: 12rpx;
  line-height: 1;
  font-family: 'LXGW WenKai', serif;
}

.share-hexagram-title {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #1C1C1C;
  margin-bottom: 28rpx;
  font-weight: 500;
  font-family: 'LXGW WenKai', serif;
}

.share-hexagram-text {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #8B8B8B;
  line-height: 1.8;
  font-family: 'LXGW WenKai', serif;
}

.share-card-footer {
  margin-top: 40rpx;
  text-align: center;
}

.share-watermark {
  font-size: 18rpx;
  color: #D0CCC2;
  letter-spacing: 6rpx;
}

.share-actions {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  width: 540rpx;
}

.share-btn {
  background-color: #1C1C1C;
  color: #F7F4EE;
  font-size: 26rpx;
  padding: 22rpx 48rpx;
  border-radius: 8rpx;
  border: none;
  letter-spacing: 2rpx;
  font-family: 'LXGW WenKai', serif;
}

.share-btn.cancel {
  background-color: transparent;
  color: #8B8B8B;
}

.share-btn::after {
  border: none;
}