/* pages/settings/settings.wxss - 设定页面 v2 */

.page {
  min-height: 100vh;
  background-color: #F7F4EE;
  display: flex;
  flex-direction: column;
  padding: 0 48rpx;
  padding-top: env(safe-area-inset-top);
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

.page-header {
  padding: 72rpx 0 44rpx 0;
}

.page-title {
  font-size: 36rpx;
  color: #1C1C1C;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.settings-list {
  flex: 1;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #E8E6E0;
}

.setting-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.setting-label {
  font-size: 28rpx;
  color: #1C1C1C;
}

.setting-desc {
  font-size: 22rpx;
  color: #8B8B8B;
}

.setting-value {
  font-size: 26rpx;
  color: #8B8B8B;
}

/* Toggle */
.toggle {
  width: 88rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  cursor: pointer;
}

.toggle-track {
  width: 88rpx;
  height: 52rpx;
  background-color: #D0CCC2;
  border-radius: 26rpx;
  padding: 4rpx;
  transition: background-color 0.3s ease;
}

.toggle.on .toggle-track {
  background-color: #1C1C1C;
}

.toggle-thumb {
  width: 44rpx;
  height: 44rpx;
  background-color: #FFFFFF;
  border-radius: 22rpx;
  transition: transform 0.3s ease;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.toggle.on .toggle-thumb {
  transform: translateX(36rpx);
}

/* 字体选项 */
.font-options {
  display: flex;
  gap: 12rpx;
}

.font-option {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1.5px solid #E0DDD5;
  border-radius: 10rpx;
  transition: all 0.2s ease;
}

.font-option.active {
  border-color: #1C1C1C;
  background-color: #1C1C1C;
}

.font-option.active .font-serif,
.font-option.active .font-sans {
  color: #F7F4EE;
}

.font-serif {
  font-size: 28rpx;
  color: #1C1C1C;
}

.font-sans {
  font-size: 28rpx;
  color: #1C1C1C;
}

/* 关于 */
.about-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 0;
  gap: 6rpx;
}

.about-text {
  font-size: 22rpx;
  color: #1C1C1C;
  letter-spacing: 6rpx;
}

.about-version {
  font-size: 18rpx;
  color: #C0BCB4;
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 0 72rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  background: transparent;
  z-index: 50;
}

.nav-item {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.35;
  transition: opacity 0.3s ease;
}

.nav-item.active {
  opacity: 1;
}

.calendar-icon {
  width: 44rpx;
  height: 44rpx;
  position: relative;
}

.calendar-icon::before {
  content: '';
  position: absolute;
  width: 38rpx;
  height: 34rpx;
  border: 1.5px solid #4A4A4A;
  border-radius: 6rpx;
  top: 4rpx;
  left: 3rpx;
  box-sizing: border-box;
}

.calendar-icon::after {
  content: '';
  position: absolute;
  width: 10rpx;
  height: 6rpx;
  border: 1.5px solid #4A4A4A;
  border-bottom: none;
  border-radius: 3rpx 3rpx 0 0;
  top: 0rpx;
  left: 50%;
  transform: translateX(-50%);
  box-sizing: border-box;
}

.settings-icon {
  width: 44rpx;
  height: 44rpx;
  position: relative;
}

.settings-icon::before {
  content: '';
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  background-color: #4A4A4A;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.settings-icon::after {
  content: '';
  position: absolute;
  width: 34rpx;
  height: 34rpx;
  border: 1.5px solid #4A4A4A;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  box-sizing: border-box;
}