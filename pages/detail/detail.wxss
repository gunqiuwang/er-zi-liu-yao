/* pages/detail/detail.wxss - 详情页 v2 */

.page {
  min-height: 100vh;
  background-color: #F7F4EE;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
  padding-top: env(safe-area-inset-top);
  padding-bottom: 160rpx;
  box-sizing: border-box;
  font-family: 'LXGW WenKai', 'Songti SC', serif;
}

.back-btn {
  width: 100%;
  padding: 32rpx 0;
}

.back-arrow {
  font-size: 48rpx;
  color: #8B8B8B;
  font-weight: 300;
}

.date-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 64rpx;
}

.solar-date {
  font-size: 28rpx;
  color: #8B8B8B;
}

.lunar-date {
  font-size: 24rpx;
  color: #BDBDBD;
}

.chars-section {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 64rpx;
}

.char-left, .char-right {
  font-size: 44rpx;
  color: #E8E4DC;
  font-weight: 200;
}

.chars {
  font-size: 144rpx;
  color: #1C1C1C;
  font-weight: 600;
  letter-spacing: 20rpx;
}

.empty-section {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-text {
  font-size: 48rpx;
  color: #D0CCC2;
  letter-spacing: 8rpx;
}

.hexagram-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  border-top: 1rpx solid #E8E6E0;
  border-bottom: 1rpx solid #E8E6E0;
  width: 100%;
  margin-bottom: 48rpx;
}

.hexagram-symbol {
  font-size: 160rpx;
  color: #1C1C1C;
  margin-bottom: 24rpx;
}

.hexagram-name {
  font-size: 56rpx;
  color: #1C1C1C;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.hexagram-title {
  font-size: 26rpx;
  color: #8B8B8B;
  margin-bottom: 32rpx;
}

.hexagram-text {
  font-size: 24rpx;
  color: #8B8B8B;
  line-height: 1.8;
  text-align: center;
  max-width: 600rpx;
}

.actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  padding: 24rpx 64rpx;
  font-size: 26rpx;
  border-radius: 10rpx;
}

.action-btn.delete {
  background-color: transparent;
  color: #8B8B8B;
  border: 1rpx solid #D0CCC2;
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 0 72rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  background: transparent;
  z-index: 50;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  opacity: 0.4;
  transition: opacity 0.3s ease;
}

.nav-item:active {
  opacity: 0.75;
}

.nav-icon {
  width: 48rpx;
  height: 48rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-label {
  font-size: 16rpx;
  color: #6A6A6A;
  letter-spacing: 2rpx;
}

/* 日历 icon */
.calendar-icon {
  width: 40rpx;
  height: 40rpx;
  border: 1.5px solid #4A4A4A;
  border-radius: 8rpx;
  position: absolute;
  opacity: 0.7;
}

.calendar-icon::before {
  content: '';
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  border: 1.5px solid #4A4A4A;
  border-bottom: none;
  border-radius: 3rpx 3rpx 0 0;
  top: -5rpx;
  left: 50%;
  transform: translateX(-50%);
  opacity: 0.7;
}

/* 设置 icon */
.settings-icon {
  width: 40rpx;
  height: 40rpx;
  border: 1.5px solid #4A4A4A;
  border-radius: 50%;
  position: absolute;
  opacity: 0.7;
}

.settings-icon::before {
  content: '';
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background-color: #4A4A4A;
  border-radius: 50%;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  opacity: 0.7;
}